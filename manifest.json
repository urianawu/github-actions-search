{
    "manifest_version": 3,
    "name": "GitHub Actions Search",
    "version": "1.0.0",
    "description": "Adds a search bar to filter workflows on GitHub Actions pages",
    "permissions": [],
    "content_scripts": [
        {
            "matches": ["https://github.com/*/actions", "https://github.com/*/actions/*"],
            "js": ["content.js"],
            "css": ["style.css"]
        }
    ],
    "icons": {
        "48": "icon.svg"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "github-actions-search@urianawu",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
